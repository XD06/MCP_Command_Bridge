# MCP Command Bridge — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env!

# Required: The bearer token clients must send as "Authorization: Bearer <token>"
# Generate one: python scripts/generate_token.py --write
MCB_TOKEN=change-me-to-a-strong-random-token

# Optional: Secrets referenced as ${NAME} in program args
# Each MCB_SECRET_<NAME> env var becomes available as ${<NAME>} in args.
# MCB_SECRET_SIYUAN_TOKEN=your-siyuan-api-token
